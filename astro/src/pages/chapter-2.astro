---
import "../styles/chapter_2.css";
const title = "Jimmy-Bean Runs · Chapter 2";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;800&family=Rajdhani:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <button id="sideToggle" class="side-toggle" type="button" aria-pressed="false">
      <span class="side-toggle-dot"></span>
      <span class="side-toggle-label">Light Side</span>
    </button>

    <button id="muteToggle" class="mute-toggle" type="button" aria-pressed="false" data-audio-toggle>
      <span class="mute-toggle-dot"></span>
      <span class="mute-toggle-label">SFX On</span>
    </button>

    <main class="chapter-shell">
      <a class="back-link" href="/">← All chapters</a>

      <section class="hero-panel">
        <div class="hero-copy">
          <p class="eyebrow" id="chapterEyebrow">Chapter 2 · May 2026</p>
          <h1>Destroy the Death Star</h1>
          <p class="lede" id="chapterDescription">
            The rebels race through May by stacking experience points from every kind of training.
          </p>
          <p class="system-copy" id="pointsExplanation">
            Scoring uses active minutes as the base, then multiplies by workout type.
          </p>
        </div>

        <div class="hero-totals">
          <article class="stat-card primary-stat">
            <p class="stat-label">Rebel XP</p>
            <div class="stat-row">
              <span id="totalPoints" class="stat-value">0</span>
              <span class="stat-sep">/</span>
              <span id="goalPoints" class="stat-goal">0</span>
              <span class="stat-unit">XP</span>
            </div>
            <div class="progress-shell">
              <div class="progress-bar">
                <div id="progressFill" class="progress-fill"></div>
              </div>
              <p id="progressText" class="progress-copy">Recruit the squad to establish the attack plan.</p>
            </div>
          </article>

          <article class="stat-card">
            <p class="stat-label">Active Time</p>
            <p id="activeTime" class="stat-value compact">0m</p>
            <p class="tiny-copy">All logged training minutes across the chapter.</p>
          </article>

          <article class="stat-card">
            <p class="stat-label">Rebel Level</p>
            <p id="rebelLevel" class="stat-value compact">1</p>
            <p class="tiny-copy">Level climbs as the fleet earns XP and diversifies training.</p>
          </article>
        </div>
      </section>

      <div id="syncBanner" class="sync-banner" data-status="idle">Connecting…</div>

      <section class="panel">
        <div class="panel-header">
          <div>
            <p class="eyebrow">Rebel Roster</p>
            <h2>Crew goals build the fleet target</h2>
          </div>
          <div class="panel-actions">
            <button id="addParticipantButton" type="button">Add Rebel</button>
            <button id="resetRunsButton" type="button" class="ghost-button">Reset Month</button>
          </div>
        </div>
        <section id="runnerGrid" class="runner-grid"></section>
      </section>

      <section class="panel">
        <div class="panel-header">
          <div>
            <p class="eyebrow">Flight Path</p>
            <h2>Advance across eight planets on the road to the trench run</h2>
          </div>
        </div>
        <p class="panel-copy">Each planet unlocks in order as the rebellion earns more XP. The route scales automatically from the total goal set by the active rebel roster.</p>
        <section id="flightPath" class="flight-path"></section>
      </section>

      <section class="panel">
        <div class="panel-header">
          <div>
            <p class="eyebrow">Ship Hangar</p>
            <h2>Unlocked ships appear here as the fleet comes online</h2>
          </div>
        </div>
        <p class="panel-copy">Locked ships stay in silhouette until their matching planet threshold is cleared.</p>
        <section id="shipGrid" class="ship-grid"></section>
      </section>

    </main>

    <dialog id="participantModal" class="modal">
      <form id="participantForm" class="modal-form">
        <div class="modal-body">
          <p id="participantModalEyebrow" class="eyebrow">New Rebel</p>
          <h2 id="participantModalTitle">Add a crew member</h2>
          <p class="panel-copy">Each rebel sets a personal monthly XP target. The chapter goal is the sum of all rebel goals.</p>
          <input id="participantId" name="participantId" type="hidden" />

          <section class="preset-guide" aria-labelledby="presetGuideTitle">
            <h3 id="presetGuideTitle">Goal Guide</h3>
            <div id="participantPresetGuide" class="preset-guide-grid"></div>
          </section>

          <label>
            <span>Name</span>
            <input id="participantName" name="participantName" type="text" maxlength="32" required />
          </label>

          <label>
            <span>Character</span>
            <select id="participantCharacter" name="characterKey" required></select>
          </label>

          <label>
            <span>Goal tier</span>
            <select id="participantGoalPreset" name="goalPreset" required></select>
          </label>

          <p id="participantGoalPresetCopy" class="panel-copy"></p>

          <label id="participantGoalWrap">
            <span>Monthly goal (XP)</span>
            <input id="participantGoal" name="goalMiles" type="number" min="1" step="1" value="600" required />
          </label>
        </div>

        <div class="modal-actions">
          <button type="button" id="cancelParticipantButton" class="ghost-button">Cancel</button>
          <button type="submit" id="saveParticipantButton">Save Rebel</button>
        </div>
      </form>
    </dialog>

    <dialog id="deleteRunModal" class="modal">
      <form method="dialog" class="modal-form">
        <div class="modal-body">
          <p class="eyebrow">Delete Entry</p>
          <h2>Remove this workout?</h2>
          <p id="deleteRunDescription" class="panel-copy"></p>
        </div>
        <div class="modal-actions">
          <button type="button" id="cancelDeleteRunButton" class="ghost-button">Keep It</button>
          <button type="button" id="confirmDeleteRunButton" class="danger-button">Delete</button>
        </div>
      </form>
    </dialog>

    <dialog id="resetModal" class="modal">
      <form method="dialog" class="modal-form">
        <div class="modal-body">
          <p class="eyebrow">Reset Month</p>
          <h2>Delete all logged workouts?</h2>
          <p class="panel-copy">This keeps the rebel roster and their goals, but clears every Chapter 2 workout entry.</p>
        </div>
        <div class="modal-actions">
          <button type="button" id="cancelResetButton" class="ghost-button">Keep Logs</button>
          <button type="button" id="confirmResetButton" class="danger-button">Confirm Reset</button>
        </div>
      </form>
    </dialog>

    <script>
      import "../scripts/chapter_2/main.js";
    </script>
  </body>
</html>
